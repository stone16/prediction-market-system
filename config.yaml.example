# config.yaml.example — PMSSettings override file
#
# PMSSettings uses pydantic-settings with an env prefix of `PMS_` and a
# nested delimiter of `__`. You can either export env vars
# (e.g. PMS_MODE=paper, PMS_RISK__MAX_TOTAL_EXPOSURE=5000) or load a YAML
# file via:
#
#     from pms.config import PMSSettings
#     settings = PMSSettings.load("config.yaml")
#
# Below are the supported top-level keys with their defaults. These defaults
# document the schema; they are not the recommended first-live envelope. For
# the 30-day paper soak before real money, start from `config.live-soak.yaml`.

mode: backtest                 # backtest | paper | live
live_trading_enabled: false    # must be true to switch into live mode
live_account_reconciliation_required: true
live_emergency_audit_path: .data/live-emergency-audit.jsonl
live_first_order_audit_path: .data/first-order-audit.jsonl
live_paper_soak_report_path: null  # mode: live requires a generated GO report
live_operator_rehearsal_report_path: null  # mode: live requires rehearsal PASS
live_preflight_artifact_path: null  # Runner.start in live requires final preflight
# mode: live rejects freshness windows wider than these values.
live_preflight_artifact_max_age_s: 3600.0
live_readiness_report_max_age_s: 604800.0
# Required only for mode: live. These are operator attestations, not legal
# advice or automated compliance checks. Fill them only after the exit
# thresholds and jurisdiction/venue review are complete.
live_exit_criteria_ratified_by: null
live_exit_criteria_ratified_at: null
live_compliance_reviewed_by: null
live_compliance_reviewed_at: null
live_compliance_jurisdiction: null

risk:
  max_position_per_market: 100.0
  max_total_exposure: 1000.0
  max_drawdown_pct: null
  max_daily_loss_usdc: null
  max_open_positions: null
  max_exposure_per_risk_group: null
  min_order_usdc: 1.0
  slippage_threshold_bps: 50.0
  max_quantity_shares: null

sensor:
  poll_interval_s: 5.0
  max_reconnect_interval_s: 60.0
  max_subscription_asset_ids: 100
  discovery_http_timeout_s: 10.0
  discovery_http_pool_timeout_s: 15.0
  discovery_http_max_connections: 50
  discovery_http_max_keepalive_connections: 20
  # Keep high-volume scan/delta history out of Postgres by default. Enable
  # these only for a bounded research-capture window.
  persist_discovery_price_snapshots: false
  persist_price_changes: false

controller:
  min_volume: 0.0
  max_slippage_bps: 50
  # Backtest/PAPER default. True LIVE validation permits only IOC or FOK until
  # PMS has a durable live open-order ledger for resting exposure.
  time_in_force: GTC
  decision_cooldown_s: 60.0
  max_book_age_ms: 1000.0
  allowed_book_clock_skew_ms: 250.0
  max_spread_bps: 100.0
  strict_factor_gates: true
  # Backtest/PAPER default. True LIVE rejects postgres_snapshot; use dual for
  # launch so the pre-submit guard compares DB and fresh venue quotes.
  quote_source: postgres_snapshot  # postgres_snapshot | venue_direct | dual
  direct_quote_min_notional_usdc: 100.0
  dual_quote_max_price_delta_bps: 25.0
  # Optional historical resolution export used to attach a no-lookahead
  # category-prior baseline to each controller decision. CSV columns:
  # market_id, category, yes_payout, no_payout, resolved_at.
  category_prior_observations_path: null
  category_prior_min_category_samples: 20
  category_prior_min_global_samples: 100
  category_prior_smoothing_alpha: 1.0
  category_prior_smoothing_beta: 1.0

database:
  pool_min_size: 2
  pool_max_size: 10
  expired_decision_retention_s: 86400.0

strategies:
  # Optional warehouse-calibrated H1 FLB model. CSV columns:
  # signal_name, probability_estimate, sample_count, source_label.
  # Required signal_name values:
  # longshot_yes_overpriced_buy_no, favorite_yes_underpriced_buy_yes.
  flb_calibration_path: null
  flb_min_calibration_samples: 100
  # Static first-live entry cost buffer; replace with paper/live telemetry.
  flb_entry_execution_cost_bps: 15.0
  flb_fee_rate: 0.07

polymarket:
  host: https://clob.polymarket.com
  websocket_url: wss://ws-subscriptions-clob.polymarket.com/ws/
  chain_id: 137
  # Keep live credentials out of config.yaml. Temporary local LIVE uses
  # secret_source: local_file plus local_secret_file pointing at a chmod 600
  # YAML file outside the repo. See docs/operations/live-polymarket-runbook.md.
  #
  # The first real-money order also needs a non-secret approval JSON file:
  #   PMS_POLYMARKET__FIRST_LIVE_ORDER_APPROVAL_PATH=/secure/pms/first-order.json
  # LIVE readiness requires every_order during the initial real-money phase.
  operator_approval_mode: first_order  # first_order | every_order
  # mode: live rejects approval freshness windows wider than 300 seconds.
  operator_approval_max_age_s: 300.0

llm:
  enabled: false
  provider: null               # e.g. "anthropic" (requires `pms[llm]`)
  model: claude-3-5-sonnet-latest

discord:
  webhook_url: null            # LIVE requires PMS_DISCORD__WEBHOOK_URL
  alert_dir: .alerts           # LIVE must use /secure/pms/alerts
