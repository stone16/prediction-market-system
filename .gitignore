.harness/*/
!.harness/retro/
!.harness/retro/**
!.harness/config.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Build artifacts
build/
dist/

# Runtime logs (never commit — may contain credentials / debug output)
*.log
pms-api.log
dashboard/dashboard.log

# Local output directories (pms-v1 harness artifacts — kept ignored so a
# stale working copy can't accidentally commit them into v2).
reports/
.data/

# Rust
target/
.review-loop/

# OpenViking memory (per-user, not committed)
.openviking/
.alerts/

# Claude worktrees (created by agent skills; local only)
.claude/

# Local secrets — env vars for LLM / Polymarket / dev DSN overrides.
# PMSSettings auto-loads .env in CWD via pydantic-settings (config.py).
# .envrc covers direnv users.
.env
.env.local
.env.*.local
.envrc

# Operator-local runtime configs. Commit the corresponding *.example files only.
config.live.yaml
config.local*.yaml
fly.live.toml

# Local API run archives.
pms-api.log.*.archive
