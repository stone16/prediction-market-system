# Non-secret LIVE runtime template.
# Copy to config.live.yaml, fill the operator/compliance fields, and keep the
# copied file local. Polymarket credentials stay in local_secret_file.

mode: live
secret_source: local_file
local_secret_file: ~/.config/pms/polymarket.local-secrets.yaml
live_trading_enabled: true
live_account_reconciliation_required: true
live_emergency_audit_path: /secure/pms/live-emergency-audit.jsonl
live_first_order_audit_path: /secure/pms/first-order-audit.jsonl
# Must match the exact final `scripts/paper_report.py --output ... --require-go`
# path; LIVE validation rejects mismatched report provenance.
live_paper_soak_report_path: /secure/pms/paper-soak-go-report.md
live_operator_rehearsal_report_path: /secure/pms/operator-rehearsal-report.md
live_execution_model_path: /secure/pms/execution-model.json
live_paper_backtest_diff_path: /secure/pms/paper-backtest-execution-diff.json
live_preflight_artifact_path: /secure/pms/credentialed-preflight.json
# LIVE validation rejects wider freshness windows than these values.
live_preflight_artifact_max_age_s: 3600.0
live_readiness_report_max_age_s: 604800.0
live_exit_criteria_ratified_by: __FILL_IN_OPERATOR_ID__
# Fill with an already-occurred ISO 8601 timestamp before final preflight.
live_exit_criteria_ratified_at: null
live_compliance_reviewed_by: __FILL_IN_REVIEWER_ID__
# Fill with an already-occurred ISO 8601 timestamp before final preflight.
live_compliance_reviewed_at: null
live_compliance_jurisdiction: __FILL_IN_JURISDICTION__

risk:
  max_position_per_market: 5.0
  max_total_exposure: 50.0
  max_drawdown_pct: 20.0
  max_daily_loss_usdc: 20.0
  max_open_positions: 5
  max_exposure_per_risk_group: 15.0
  min_order_usdc: 1.0
  slippage_threshold_bps: 50.0
  max_quantity_shares: 500.0

sensor:
  poll_interval_s: 5.0
  max_reconnect_interval_s: 60.0
  max_subscription_asset_ids: 100
  persist_discovery_price_snapshots: false
  persist_price_changes: false

controller:
  min_volume: 0.0
  max_slippage_bps: 50
  time_in_force: IOC
  decision_cooldown_s: 60.0
  max_book_age_ms: 1000.0
  allowed_book_clock_skew_ms: 250.0
  max_spread_bps: 100.0
  strict_factor_gates: true
  quote_source: dual
  direct_quote_min_notional_usdc: 100.0
  dual_quote_max_price_delta_bps: 25.0
  # Historical resolution export used to attach a no-lookahead category-prior
  # baseline to each controller decision. Preflight/startup fail closed when
  # the file is missing, malformed, or below the configured global sample gate.
  category_prior_observations_path: /secure/pms/category-prior-observations.csv
  category_prior_min_category_samples: 20
  category_prior_min_global_samples: 100
  category_prior_smoothing_alpha: 1.0
  category_prior_smoothing_beta: 1.0

strategies:
  # Warehouse-calibrated H1 FLB model staged on the private launch volume.
  # Preflight/startup fail closed when the file is missing or schema/sample
  # gates fail.
  # CSV columns: signal_name, probability_estimate, sample_count, source_label.
  flb_calibration_path: /secure/pms/flb-calibration.csv
  flb_min_calibration_samples: 100
  flb_entry_execution_cost_bps: 15.0
  flb_fee_rate: 0.04

discord:
  # Secret webhook URL intentionally omitted; stage it with
  # PMS_DISCORD__WEBHOOK_URL. LIVE validation rejects missing webhook_url.
  # Non-secret fallback path for dropped Discord alerts. LIVE validation
  # rejects runs when this path stays inside the working tree.
  alert_dir: /secure/pms/alerts

polymarket:
  operator_approval_mode: every_order
  first_live_order_approval_path: /secure/pms/first-order.json
  # LIVE validation rejects approval freshness windows wider than 300 seconds.
  operator_approval_max_age_s: 300.0

llm:
  # Keep LLM opt-in for the first real-money path. Set enabled=true only after
  # staging PMS_LLM__API_KEY and accepting the added dependency/cost surface.
  enabled: false
  provider: anthropic
  max_daily_llm_cost_usdc: 25.0
